{
  "name": "ZapRocket - Webhook Receiver",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "zaprocket-webhook",
        "options": {}
      },
      "id": "c1615f7a-8bfc-4861-bbdf-5da66f07d2f4",
      "name": "Webhook ZapRocket",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "zaprocket-webhook-custom-id"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.item.json.body;\nconst leadInfo = data.lead;\nconst messageText = data.message;\nconst base64Image = data.image;\nconst tags = data.tags;\n\n// Procura heuristica pelo número de celular\nlet phone = '';\nconst keys = Object.keys(leadInfo);\nfor (const k of keys) {\n  if (k.toLowerCase().includes('telefone') || k.toLowerCase().includes('phone') || k.toLowerCase().includes('numero') || k.toLowerCase().includes('celular')) {\n    phone = leadInfo[k];\n    break;\n  }\n}\nif (!phone) phone = leadInfo[keys[1]]; // fallback p/ 2ª coluna\n\n// Remove caracteres não numéricos\nphone = phone.toString().replace(/\\D/g, '');\n// Se não tiver código de país, adiciona (Assumindo Brasil 55)\nif (phone.length <= 11) {\n    phone = '55' + phone;\n}\n\n// Verifica se tem imagem\nconst hasImage = !!base64Image;\n\nreturn {\n  json: {\n    number: phone,\n    text: messageText,\n    hasImage: hasImage,\n    base64Data: hasImage ? base64Image.split(',')[1] : null,\n    tags: tags,\n    providerInfo: \"Envie esta estrutura para a requisição da Evolution API/WPPCloud\"\n  }\n};"
      },
      "id": "e2e8310c-30b6-4b67-8e6d-625b5ce3660f",
      "name": "Code Parser",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://SUA_API_EVOLUTION_OU_WHATSAPP/message/sendText={{$json.number}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "SUA_API_KEY"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
