              "name": "number",
              "value": "={{$json.number}}"
            },
            {
              "name": "options",
              "value": "={ \"delay\": 1200, \"presence\": \"composing\" }"
            },
            {
              "name": "textMessage",
              "value": "={{$json.text}}"
            }
          ]
        },
        "options": {}
      },
      "id": "f5c9e2c7-2c5c-5c2b-ac2b-2b3c4d5e6f7a",
